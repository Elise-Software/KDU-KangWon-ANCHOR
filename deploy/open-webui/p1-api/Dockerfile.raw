FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app
COPY requirements-raw.txt /app/requirements-raw.txt
RUN pip install --upgrade pip \
    && pip install -r /app/requirements-raw.txt

COPY raw_proxy.py /app/raw_proxy.py
RUN useradd --create-home --uid 10001 wonju \
    && chown -R wonju:wonju /app
USER wonju

EXPOSE 8020
CMD ["uvicorn", "raw_proxy:app", "--host", "0.0.0.0", "--port", "8020"]
