# Public gateway
HTTP_PORT=80
PUBLIC_BASE_URL=http://localhost

# Open WebUI bootstrap administrator (change every value before deployment)
WEBUI_ADMIN_NAME=원주시 생활건강 관리자
WEBUI_ADMIN_EMAIL=admin@example.invalid
WEBUI_ADMIN_PASSWORD=replace-with-a-long-random-password
WEBUI_SECRET_KEY=replace-with-at-least-32-random-bytes
OPEN_WEBUI_JWT_SECRET=replace-with-a-different-32-byte-secret

# Internal service credentials. These ports are not published by Compose.
P1_INTERNAL_API_KEY=replace-with-a-long-random-p1-key
RAW_PROXY_INTERNAL_API_KEY=replace-with-a-long-random-raw-proxy-key

# Existing P1 generation endpoint
VLLM_BASE_URL=http://wonju-vllm:8000/v1
P1_MODEL_OFFLINE=0
VLLM_API_KEY=
RAW_MODEL_ID=gemma-4-31b-nvfp4

# Comma-separated existing Open WebUI accounts. This list is the source of
# truth for membership in the developer group and raw-model proxy access.
DEVELOPER_EMAILS=developer@example.invalid
DEVELOPER_GROUP_NAME=개발자
PERMISSION_SYNC_INTERVAL_SECONDS=60

# The first P1 API start loads bge-m3 and bge-reranker-v2-m3 before readiness.
P1_PRELOAD_MODELS=true

# Reproducible upstream UI image. Change only after overlay/tests are verified.
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.9.6
